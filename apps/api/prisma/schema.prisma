// PixStudio Prisma schema — Sprint 1 minimum (workspace + user + project + asset)
// Phase 2+ adds: ai_jobs, usage_tracker, stock_accounts, brand_kits, templates,
//                rag_documents (pgvector), comments, versions, presence
// Reference: docs/cto/CTO-TECH-STACK-v04.md §3 (18 model schema)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

// =============================================================================
// AUTH (better-auth integration — Sprint 1)
// =============================================================================

enum SystemRole {
  ADMIN  // anh + Tùng — full system access (stock library, tier overrides, view all workspaces, billing)
  MOD    // senior marketers — review flagged content, support tickets, Crossian KB updates
  USER   // default — scoped to own workspaces
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  emailVerified Boolean    @default(false)
  name          String?
  image         String?
  systemRole    SystemRole @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  workspaceMembers  WorkspaceMember[]
  ownedWorkspaces   Workspace[]      @relation("WorkspaceOwner")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  providerId        String
  accountId         String
  password          String?  // hashed via better-auth
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("verifications")
}

// =============================================================================
// WORKSPACE + MEMBERSHIP (Sprint 1)
// =============================================================================

enum BillingTier {
  STANDARD
  PRO
  MAX
}

enum WorkspaceRegion {
  VN_SG  // APAC default Phase 1
  EU
  US
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  ownerId      String
  region       WorkspaceRegion @default(VN_SG)
  billingTier  BillingTier     @default(STANDARD)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members  WorkspaceMember[]
  projects Project[]
  brandKit BrandKit?

  @@index([ownerId])
  @@map("workspaces")
}

// =============================================================================
// BRAND KIT (Sprint 3 Story 3.1 — Pro+ tier)
// =============================================================================

model BrandKit {
  id              String   @id @default(uuid())
  workspaceId     String   @unique
  logoR2Key       String?  // R2 object key (logo file uploaded via presigned URL)
  faviconR2Key    String?  // R2 object key (favicon)
  primaryColor    String   @default("#3B82F6") // hex e.g. PXL royal
  secondaryColor  String?  // hex
  accentColor     String?  // hex
  fontFamily      String?  // e.g. "Inter" / "Bebas Neue"
  watermarkText   String?  // e.g. "PXL-XXXXX"
  watermarkOn     Boolean  @default(true) // toggle watermark for Pro+ tier
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("brand_kits")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  workspaceId String
  userId      String
  role        MemberRole @default(EDITOR)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

// =============================================================================
// PROJECT (Sprint 1)
// =============================================================================

model Project {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  description  String?
  yjsDocId     String?  // Phase 3 collab — reserved Sprint 1, populated when Yjs ships
  thumbnailKey String?  // R2 key
  // Sprint 3 Story 3.3: editor state JSON (serialized timeline / scenes / settings).
  // Auto-saved every 30s via debounced PATCH from web client. Versions snapshot on
  // demand or major operations (rename / scene add/remove).
  editorStateJson Json?
  editorStateVersion Int @default(0) // monotonic increment per save (for conflict detection)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastEditedAt DateTime @default(now())
  archived     Boolean  @default(false)

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assets             Asset[]
  quickCreateSessions QuickCreateSession[]
  versions           ProjectVersion[]
  comments           ProjectComment[]

  @@index([workspaceId])
  @@index([lastEditedAt])
  @@map("projects")
}

// =============================================================================
// PROJECT VERSION (Sprint 3 Story 3.3 — version history)
// =============================================================================

model ProjectVersion {
  id              String   @id @default(uuid())
  projectId       String
  versionNumber   Int      // monotonic, matches Project.editorStateVersion at snapshot time
  editorStateJson Json     // full snapshot of editor state
  label           String?  // optional user label e.g. "Before scene reorder"
  triggeredBy     String   // user.id who saved
  triggerReason   String   // "auto-save" | "manual" | "rename" | "scene-change" | "milestone"
  thumbnailKey    String?  // optional snapshot thumbnail R2 key
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId, createdAt])
  @@map("project_versions")
}

// =============================================================================
// PROJECT COMMENT (Sprint S26 — Frame.io-style timestamped comments, PW-30)
// =============================================================================

model ProjectComment {
  id              String         @id @default(uuid())
  projectId       String
  authorId        String         // user.id
  /** Optional segment to anchor comment to. */
  segmentId       String?
  /** Optional video timestamp (sec). */
  timestampSec    Decimal?       @db.Decimal(10, 3)
  body            String         // markdown supported
  status          CommentStatus  @default(OPEN)
  parentCommentId String?        // for threaded replies (1-level)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resolvedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent  ProjectComment? @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies ProjectComment[] @relation("CommentThread")

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@map("project_comments")
}

enum CommentStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

// =============================================================================
// ASSET (Sprint 1 minimal — expand Sprint 2 với AI gen + stock pool)
// =============================================================================

enum AssetType {
  VIDEO
  IMAGE
  MUSIC
  CHARACTER
  SCRIPT
  TTS_AUDIO        // Phase 2+ ElevenLabs output
  AI_GEN_IMAGE     // Phase 2+ Nano Banana / Seedream
  AI_GEN_VIDEO     // Phase 2+ Seedance / Veo / Kling
}

enum AssetSource {
  USER_UPLOAD
  STOCK_POOL       // Phase 2+ admin pool
  AI_GEN           // Phase 2+ generative
  TEMPLATE         // Phase 2+ template clone
}

model Asset {
  id           String      @id @default(uuid())
  projectId    String
  type         AssetType
  source       AssetSource @default(USER_UPLOAD)
  name         String
  r2Key        String      // bucket/path in pxs-vn-sg-uploads
  mimeType     String
  sizeBytes    BigInt
  durationMs   Int?        // for video/audio
  width        Int?        // for video/image
  height       Int?        // for video/image
  metadata     Json?       // type-specific (codec, fps, bitrate, license_id, etc.)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@map("assets")
}

// =============================================================================
// STOCK LIBRARY (Sprint 5 Story 4.1 — admin only, anh manages 10-20 accounts)
// =============================================================================

enum StockVendor {
  ISTOCK
  ENVATO
  SHUTTERSTOCK
}

enum StockAccountStatus {
  ACTIVE
  RATE_LIMITED
  EXPIRED
  DISABLED
}

model StockAccount {
  id                String              @id @default(uuid())
  vendor            StockVendor
  label             String
  apiCredentialsKey String
  monthlyQuota      Int
  monthlyUsed       Int                 @default(0)
  resetDayOfMonth   Int                 @default(1)
  status            StockAccountStatus  @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  downloads StockDownload[]

  @@index([vendor, status])
  @@map("stock_accounts")
}

model StockDownload {
  id              String   @id @default(uuid())
  accountId       String
  workspaceId     String
  userId          String
  projectId       String?
  vendorAssetId   String
  vendorPreviewUrl String?
  vendorLicenseId String?
  r2Key           String
  costCents       Int      @default(0)
  createdAt       DateTime @default(now())

  account StockAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([workspaceId])
  @@map("stock_downloads")
}

// =============================================================================
// PATH B REVERSE ENGINEER (Sprint 5 Stories 2.1-2.8)
// =============================================================================

enum ReverseEngineerStatus {
  PENDING
  DOWNLOADING
  EXTRACTING_AUDIO
  DETECTING_SCENES
  SEPARATING_STEMS
  TRANSCRIBING
  IDENTIFYING_MUSIC
  ANALYZING_VISUAL
  BUILDING_STATE
  COMPLETED
  FAILED
  CANCELLED
}

model ReverseEngineerJob {
  id                    String                @id @default(uuid())
  sessionId             String                @unique
  userId                String
  workspaceId           String
  sourceUrl             String?
  sourceAssetId         String?
  gpuDropletId          String?
  status                ReverseEngineerStatus @default(PENDING)
  progress              Int                   @default(0)
  errorMessage          String?
  outputEditorStateJson Json?
  totalCostUsd          Decimal               @default(0) @db.Decimal(10, 6)
  totalDurationMs       Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  completedAt           DateTime?

  @@index([userId])
  @@index([status])
  @@map("reverse_engineer_jobs")
}

// =============================================================================
// USAGE TRACKER (Sprint 6 — tier quota enforcement)
// =============================================================================

model UsageTracker {
  id                       String   @id @default(uuid())
  workspaceId              String
  monthYear                String
  buildsCount              Int      @default(0)
  pathBMinutes             Decimal  @default(0) @db.Decimal(10, 2)
  voicePreviewsCount       Int      @default(0)
  totalCostUsd             Decimal  @default(0) @db.Decimal(10, 6)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([workspaceId, monthYear])
  @@index([workspaceId])
  @@map("usage_trackers")
}

// =============================================================================
// CROSSIAN RAG DOCUMENTS (Sprint 6 — pgvector EN dropshipping/facebook-ad only)
// =============================================================================

model RagDocument {
  id           String                       @id @default(uuid())
  source       String
  contentType  String
  workflowTags String[]
  language     String                       @default("en")
  content      String                       @db.Text
  /// pgvector 768-dim embedding (Gemini text-embedding-004). Sprint 36.
  embedding    Unsupported("vector(768)")?
  sanitizedAt  DateTime                     @default(now())
  sanitizeRules String[]
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  @@index([contentType])
  @@map("rag_documents")
}

// =============================================================================
// BUG REPORTS (Sprint 7 — internal alpha bug bash)
// =============================================================================

enum BugSeverity {
  P0
  P1
  P2
  P3
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  FIXED
  WONT_FIX
  DUPLICATE
}

model BugReport {
  id           String      @id @default(uuid())
  reporterId   String
  workspaceId  String?
  projectId    String?
  title        String
  description  String      @db.Text
  severity     BugSeverity @default(P2)
  status       BugStatus   @default(OPEN)
  pageUrl      String?
  userAgent    String?
  consoleErrors String?    @db.Text
  screenshotR2Key String?
  assignedTo   String?
  resolvedAt   DateTime?
  resolution   String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([reporterId])
  @@index([status, severity])
  @@map("bug_reports")
}

// =============================================================================
// QUICK CREATE (Phase 1 Sprint 2)
// =============================================================================

enum QuickCreateMode {
  PATH_A
  PATH_B
}

enum BuildStatus {
  PENDING
  GENERATING_SCRIPT
  SYNTHESIZING_VOICE
  MATCHING_STOCK
  COMPOSING_SCENES
  RENDERING_PREVIEW
  COMPLETED
  FAILED
  CANCELLED
}

model QuickCreateSession {
  id                 String          @id @default(uuid())
  userId             String
  workspaceId        String
  workflowId         String?

  prompt             String          @db.Text
  mode               QuickCreateMode @default(PATH_A)
  pathBSourceJson    Json?

  configOverrides    Json            @default("{}")
  outlineJson        Json?
  chipSelectionsJson Json?

  buildJobId         String?
  buildStatus        BuildStatus     @default(PENDING)
  buildProgress      Int             @default(0)
  buildErrorMessage  String?

  projectId          String?
  totalCostUsd       Decimal         @default(0) @db.Decimal(10, 6)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  completedAt        DateTime?

  project            Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([workflowId])
  @@index([buildStatus])
  @@map("quick_create_sessions")
}

